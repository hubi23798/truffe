# Postgres connection string.
#
# LOCAL DEV (Homebrew Postgres): no user/password required.
DATABASE_URL=postgres://localhost:5432/boink
# Homebrew Postgres: use postgres://localhost:5432/<dbname> with no
# username or password. Database name should match the project (boink).
#
# SUPABASE (production / production-parity dev): copy from
#   Supabase dashboard → Project Settings → Database → Connection string → URI
# Format: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
# Example:
# DATABASE_URL=postgresql://postgres:your-db-password@db.abcdefghijk.supabase.co:5432/postgres

# WebAuthn relying party
# RP_ID is the host (no scheme/port). For production use your domain.
RP_ID=localhost
RP_NAME=boink!
ORIGIN=http://localhost:3000

# Cookie names.
#
# In LOCAL HTTP DEV, leave these unset (defaults: "session" / "enrollment").
# Plain HTTP can't satisfy the __Host- prefix's Secure requirement, so the
# defaults stay spec-valid by not using __Host-.
#
# In PRODUCTION (HTTPS), explicitly set these to the __Host- variants:
#     SESSION_COOKIE_NAME=__Host-session
#     ENROLLMENT_COOKIE_NAME=__Host-enrollment
# In production NODE_ENV=production also flips Secure=true on the cookies
# (see src/lib/auth/cookies.ts), which the __Host- prefix requires.
#
# SESSION_COOKIE_NAME=session
# ENROLLMENT_COOKIE_NAME=enrollment

# First-deploy enrollment secret. Required by POST /api/auth/bootstrap/init
# to mint a single-use bootstrap token over HTTP. Set this on first deploy,
# enroll your first passkey, then UNSET it.
#   vercel env add BOOTSTRAP_INIT_SECRET   (or via dashboard)
# BOOTSTRAP_INIT_SECRET=<long-random-string>

# Advisor cost ceiling (tokens/day, totalled across input + output)
ADVISOR_DAILY_TOKEN_BUDGET=200000
