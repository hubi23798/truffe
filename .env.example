# Postgres connection string (Fly Postgres provides one in production)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/finance

# WebAuthn relying party
# RP_ID is the host (no scheme/port). For production use your domain.
RP_ID=localhost
RP_NAME=boink!
ORIGIN=http://localhost:3000

# Cookie names.
#
# In LOCAL HTTP DEV, leave these unset (defaults: "session" / "enrollment").
# Plain HTTP can't satisfy the __Host- prefix's Secure requirement, so the
# defaults stay spec-valid by not using __Host-.
#
# In PRODUCTION (HTTPS), explicitly set these to the __Host- variants:
#     SESSION_COOKIE_NAME=__Host-session
#     ENROLLMENT_COOKIE_NAME=__Host-enrollment
# In production NODE_ENV=production also flips Secure=true on the cookies
# (see src/lib/auth/cookies.ts), which the __Host- prefix requires.
#
# SESSION_COOKIE_NAME=session
# ENROLLMENT_COOKIE_NAME=enrollment

# Advisor cost ceiling (tokens/day, totalled across input + output)
ADVISOR_DAILY_TOKEN_BUDGET=200000
